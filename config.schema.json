{
  "pluginAlias": "TasmotaZbBridge",
  "pluginType": "platform",
  "singular": true,
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string",
        "required": true
      },
      "zigbee2TasmotaDevices": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "addr",
            "type",
            "name"
          ],
          "properties": {
            "addr": {
              "type": "string",
              "pattern": "^0x([A-Fa-f0-9]{4}|[A-Fa-f0-9]{16})(:[1-9]{1}[0-9]{0,2})?$"
            },
            "type": {
              "type": "string",
              "enum": [
                "light0",
                "light1",
                "light2",
                "light3",
                "light4",
                "light5",
                "light_XY_B_CT",
                "switch",
                "sensor"
              ]
            },
            "name": {
              "type": "string"
            },
            "powerTopic": {
              "type": "string"
            },
            "powerType": {
              "type": "string",
              "enum": [
                "POWER",
                "POWER1",
                "POWER2",
                "POWER3",
                "POWER4"
              ]
            },
            "sensorService": {
              "type": "string",
              "enum": [
                "AccessCode",
                "AccessControl",
                "AccessoryInformation",
                "AccessoryMetrics",
                "AccessoryRuntimeInformation",
                "AirPurifier",
                "AirQualitySensor",
                "AssetUpdate",
                "Assistant",
                "AudioStreamManagement",
                "Battery",
                "BridgeConfiguration",
                "BridgingState",
                "CameraControl",
                "CameraOperatingMode",
                "CameraRecordingManagement",
                "CameraRTPStreamManagement",
                "CarbonDioxideSensor",
                "CarbonMonoxideSensor",
                "CloudRelay",
                "ContactSensor",
                "DataStreamTransportManagement",
                "Diagnostics",
                "Door",
                "Doorbell",
                "Fan",
                "Fanv2",
                "Faucet",
                "FilterMaintenance",
                "GarageDoorOpener",
                "HeaterCooler",
                "HumidifierDehumidifier",
                "HumiditySensor",
                "InputSource",
                "IrrigationSystem",
                "LeakSensor",
                "Lightbulb",
                "LightSensor",
                "LockManagement",
                "LockMechanism",
                "Microphone",
                "MotionSensor",
                "NFCAccess",
                "OccupancySensor",
                "Outlet",
                "Pairing",
                "PowerManagement",
                "ProtocolInformation",
                "SecuritySystem",
                "ServiceLabel",
                "Siri",
                "SiriEndpoint",
                "Slats",
                "SmartSpeaker",
                "SmokeSensor",
                "Speaker",
                "StatefulProgrammableSwitch",
                "StatelessProgrammableSwitch",
                "Switch",
                "TargetControl",
                "TargetControlManagement",
                "Television",
                "TelevisionSpeaker",
                "TemperatureSensor",
                "Thermostat",
                "ThreadTransport",
                "TimeInformation",
                "TransferTransportManagement",
                "Tunnel",
                "Valve",
                "WiFiRouter",
                "WiFiSatellite",
                "WiFiTransport",
                "Window",
                "WindowCovering"
              ]
            },
            "sensorCharacteristic": {
              "type": "string"
            },
            "sensorValuePath": {
              "type": "string"
            },
            "sensorValueMapping": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "from",
                  "to"
                ],
                "properties": {
                  "from": {
                    "type": "string"
                  },
                  "to": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      },
      "zigbee2mqttDevices": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "ieee_address": {
              "type": "string",
              "pattern": "^0x[A-Fa-f0-9]{16}$",
              "required": true
            },
            "name": {
              "type": "string"
            },
            "powerTopic": {
              "type": "string"
            },
            "powerType": {
              "type": "string",
              "enum": [
                "POWER",
                "POWER1",
                "POWER2",
                "POWER3",
                "POWER4"
              ]
            }
          }
        }
      },
      "tasmotaDevices": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "topic",
            "type",
            "name"
          ],
          "properties": {
            "topic": {
              "type": "string"
            },
            "type": {
              "type": "string",
              "enum": [
                "SWITCH",
                "LIGHTBULB",
                "LIGHTBULB_B",
                "LIGHTBULB_B_CT",
                "LIGHTBULB_B_HS",
                "LIGHTBULB_B_HS_CT",
                "LIGHTBULB_B_CH",
                "VALVE",
                "LOCK",
                "BUTTON",
                "CONTACT",
                "SENSOR",
                "CUSTOM"
              ]
            },
            "index": {
              "type": "string",
              "enum": [
                "1",
                "2",
                "3",
                "4",
                "5",
                "6",
                "7",
                "8"
              ]
            },
            "name": {
              "type": "string"
            },
            "custom": {
              "type": "string"
            }
          }
        }
      },
      "mqttBroker": {
        "type": "string"
      },
      "mqttUsername": {
        "type": "string"
      },
      "mqttPassword": {
        "type": "string"
      },
      "zigbee2tasmotaTopic": {
        "type": "string"
      },
      "zigbee2mqttTopic": {
        "type": "string"
      },
      "logTimeouts": {
        "type": "boolean"
      },
      "logUnexpected": {
        "type": "boolean"
      }
    }
  },
  "layout": [
    {
      "key": "name",
      "default": "ZbBridge",
      "placeholder": "Homebridge name for the TasmotaZbBridge platform"
    },
    {
      "key": "zigbee2TasmotaDevices",
      "title": "Zigbee2Tasmota Devices",
      "expandable": true,
      "expanded": false,
      "orderable": false,
      "buttonText": "Add Device",
      "default": [],
      "items": [
        {
          "type": "div",
          "displayFlex": false,
          "items": [
            {
              "type": "flex",
              "flex-flow": "row",
              "items": [
                {
                  "key": "zigbee2TasmotaDevices[].addr",
                  "placeholder": "ShortAddr or IEEEAddr"
                },
                {
                  "key": "zigbee2TasmotaDevices[].type",
                  "titleMap": {
                    "light0": "Simple On/Off Light",
                    "light1": "White Light with Dimmer",
                    "light2": "White Light with Dimmer and Cold/Warm White",
                    "light3": "RGB Light",
                    "light4": "RGBW Light",
                    "light5": "RGBCW Light, RGB and Cold/Warm White",
                    "light_XY_B_CT": "RGB (With XY color and CT)",
                    "switch": "On/Off Switch",
                    "sensor": "Sensor"
                  }
                },
                {
                  "key": "zigbee2TasmotaDevices[].name",
                  "placeholder": "HomeKit name"
                }
              ]
            },
            {
              "type": "fieldset",
              "title": "Advanced",
              "expandable": true,
              "expanded": false,
              "items": [
                {
                  "type": "help",
                  "helpvalue": "Use separate tasmota device to control the power on/off function of the device"
                },
                {
                  "type": "flex",
                  "flex-flow": "row",
                  "items": [
                    {
                      "key": "zigbee2TasmotaDevices[].powerTopic"
                    },
                    {
                      "key": "zigbee2TasmotaDevices[].powerType",
                      "titleMap": {
                        "POWER": "Switch",
                        "POWER1": "Switch 1",
                        "POWER2": "Switch 2",
                        "POWER3": "Switch 3",
                        "POWER4": "Switch 4"
                      }
                    }
                  ]
                },
                {
                  "type": "help",
                  "helpvalue": "Sensor device configuration, see <a href='https://developers.homebridge.io/#/service'>here</a> for detailed explanation"
                },
                {
                  "type": "flex",
                  "flex-flow": "row",
                  "items": [
                    {
                      "key": "zigbee2TasmotaDevices[].sensorService"
                    },
                    {
                      "key": "zigbee2TasmotaDevices[].sensorCharacteristic"
                    },
                    {
                      "key": "zigbee2TasmotaDevices[].sensorValuePath"
                    }
                  ]
                },
                {
                  "type": "fieldset",
                  "title": "Sensor Value Mapping",
                  "expandable": true,
                  "expanded": false,
                  "items": [
                    {
                      "type": "help",
                      "helpvalue": "ZbBridge sensor values could be mapped to homebridge characteristic values here"
                    },
                    {
                      "key": "zigbee2TasmotaDevices[].sensorValueMapping",
                      "notitle": true,
                      "buttonText": "Add Mapping",
                      "items": [
                        {
                          "type": "flex",
                          "flex-flow": "row",
                          "items": [
                            {
                              "key": "zigbee2TasmotaDevices[].sensorValueMapping[].from",
                              "placeholder": "From Value"
                            },
                            {
                              "key": "zigbee2TasmotaDevices[].sensorValueMapping[].to",
                              "placeholder": "To Value"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "key": "zigbee2mqttDevices",
      "title": "Zigbee2MQTT Devices",
      "expandable": true,
      "expanded": false,
      "orderable": false,
      "buttonText": "Add Device",
      "default": [],
      "items": [
        {
          "type": "div",
          "displayFlex": false,
          "items": [
            {
              "type": "flex",
              "flex-flow": "row",
              "items": [
                {
                  "key": "zigbee2mqttDevices[].ieee_address",
                  "title": "Device Addr",
                  "placeholder": "IEEEAddr"
                },
                {
                  "key": "zigbee2mqttDevices[].name",
                  "placeholder": "HomeKit name"
                }
              ]
            },
            {
              "type": "flex",
              "nodescription": true,
              "flex-flow": "row",
              "items": [
                {
                  "key": "zigbee2mqttDevices[].powerTopic"
                },
                {
                  "key": "zigbee2mqttDevices[].powerType",
                  "titleMap": {
                    "POWER": "Switch",
                    "POWER1": "Switch 1",
                    "POWER2": "Switch 2",
                    "POWER3": "Switch 3",
                    "POWER4": "Switch 4"
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "key": "tasmotaDevices",
      "title": "Tasmota Devices",
      "expandable": true,
      "expanded": false,
      "orderable": false,
      "buttonText": "Add Device",
      "default": [],
      "items": [
        {
          "type": "div",
          "displayFlex": false,
          "items": [
            {
              "type": "flex",
              "flex-flow": "row",
              "items": [
                {
                  "key": "tasmotaDevices[].topic"
                },
                {
                  "key": "tasmotaDevices[].type",
                  "titleMap": {
                    "SWITCH": "Switch",
                    "LIGHTBULB": "Light",
                    "LIGHTBULB_B": "Dimmable Light",
                    "LIGHTBULB_B_CT": "CCT Light",
                    "LIGHTBULB_B_HS": "RGB Light",
                    "LIGHTBULB_B_HS_CT": "RGBCCT Light",
                    "LIGHTBULB_B_CH": "PWM Channel",
                    "VALVE": "Valve",
                    "LOCK": "Lock Mechanism",
                    "BUTTON": "Button",
                    "CONTACT": "ContactSensor",
                    "SENSOR": "Autodetect sensors",
                    "CUSTOM": "Custom definition"
                  }
                },
                {
                  "key": "tasmotaDevices[].index"
                },
                {
                  "key": "tasmotaDevices[].name",
                  "title": "HomeKit name"
                }
              ]
            },
            {
              "type": "fieldset",
              "condition": {
                "functionBody": "try { return model.tasmotaDevices[arrayIndices[0]].type === 'CUSTOM'; } catch(e) { return false; }"
              },
              "items": [
                {
                  "type": "help",
                  "helpvalue": "Custom device definition, see <a href='https://github.com/mdaskalov/homebridge-tasmota-zbbridge/blob/main/doc/TasmotaDeviceDefinition.md'>here</a> for detailed explanation"
                },
                {
                  "type": "textarea",
                  "key": "tasmotaDevices[].custom",
                  "title": "Custom Definition"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "type": "fieldset",
      "title": "MQTT Settings",
      "expandable": true,
      "expanded": false,
      "items": [
        {
          "key": "mqttBroker",
          "title": "Hostname",
          "placeholder": "MQTT Broker hostname if not localhost",
          "format": "hostname"
        },
        {
          "type": "flex",
          "flex-flow": "row",
          "items": [
            {
              "key": "mqttUsername",
              "title": "Username",
              "placeholder": "MMQTT Broker username if passwort protected"
            },
            {
              "key": "mqttPassword",
              "title": "Password",
              "placeholder": "MQTT Broker passwort if passwort protected",
              "format": "password"
            }
          ]
        },
        {
          "key": "zigbee2tasmotaTopic",
          "title": "Zigbee2Tasmota MQTT topic",
          "placeholder": "Zigbee2Tasmota device identifying topic (default: zbbridge)"
        },
        {
          "key": "zigbee2mqttTopic",
          "title": "Zigbee2MQTT MQTT topic",
          "placeholder": "Zigbee2MQTT base topic (default: zigbee2mqtt)"
        },
        {
          "key": "logTimeouts",
          "title": "Write MQTT command response timeouts in log"
        },
        {
          "key": "logUnexpected",
          "title": "Write unexpected command responses in log"
        }
      ]
    }
  ]
}